{
  "expo": {
    "name": "SDA Community App",
    "slug": "sda-community",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sda-community",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "152",
      "bundleIdentifier": "com.sdacommunity.app",
      "infoPlist": {
        "CFBundleDisplayName": "SDA Community",
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "SDA Community uses your camera for video calls.",
        "NSMicrophoneUsageDescription": "SDA Community uses your microphone for voice and video calls.",
        "NSPhotoLibraryUsageDescription": "SDA Community uses your photo library when you choose images for posts and profile updates.",
        "NSPhotoLibraryAddUsageDescription": "SDA Community saves media to your photo library when you choose to download content.",
        "NSLocationWhenInUseUsageDescription": "SDA Community uses your location to improve nearby church and community experiences."
      }
    },
    "android": {
      "backgroundColor": "#0A0A0A"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://bf38caff-17cb-42b3-9bbe-f4a70b83300a-00-3ekt4pzyxikvn.janeway.replit.dev/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "@livekit/react-native-expo-plugin",
        {
          "android": {
            "audioType": "communication"
          },
          "ios": {
            "enableMultitaskingCameraAccess": false
          }
        }
      ],
      "@config-plugins/react-native-webrtc",
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://bf38caff-17cb-42b3-9bbe-f4a70b83300a-00-3ekt4pzyxikvn.janeway.replit.dev/"
      },
      "eas": {
        "projectId": "86a3cc72-d8a2-415c-a2d5-4fd8864f89f1"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/86a3cc72-d8a2-415c-a2d5-4fd8864f89f1",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "owner": "kojo_toku54"
  }
}
