# ── Clerk Auth ────────────────────────────────────────────────
# Get this from https://dashboard.clerk.com → Your App → API Keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Supabase Database ─────────────────────────────────────────
# Get these from https://supabase.com → Your Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe Payments ───────────────────────────────────────────
# Get this from https://dashboard.stripe.com → Developers → API Keys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── LiveKit (video/audio calls) ───────────────────────────────
# WSS URL of your LiveKit project (LiveKit Cloud or self-hosted)
EXPO_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
# Endpoint on api-server that mints per-user access tokens.
# In dev this is http://<your-lan-ip>:4000/livekit/token (matches LIVEKIT_API_KEY/SECRET set on api-server).
EXPO_PUBLIC_LIVEKIT_TOKEN_ENDPOINT=https://your-api-server.example.com/livekit/token
# Optional: short-lived static token for quick testing only. Leave blank in production.
EXPO_PUBLIC_LIVEKIT_TOKEN=
# Optional: customise the room name prefix (defaults to SDACommunity).
EXPO_PUBLIC_LIVEKIT_ROOM_PREFIX=SDACommunity
